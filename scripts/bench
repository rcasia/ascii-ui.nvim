#!/bin/bash
# Run performance benchmarks.
# Mirrors scripts/test but targets tests/bench/ only and does not fail
# the run on luacov absence.

tempfile=$(mktemp)
minimal="tests/minimal.lua"
plugins_dir="./.tests/site/pack/deps/start"

function setup_environment() {
  if [[ ! -d "${plugins_dir}" ]]; then
    mkdir -p "${plugins_dir}"
  fi

  if [[ ! -d "${plugins_dir}/plenary.nvim" ]]; then
    echo "[bench] installing plenary.nvim..."
    git clone https://github.com/nvim-lua/plenary.nvim "${plugins_dir}/plenary.nvim"
    local -r plenary_353_patch="$(pwd)/scripts/plenary-353.patch"
    git -C "${plugins_dir}/plenary.nvim" apply "${plenary_353_patch}"
  fi
}

setup_environment

nvim --headless --noplugin -u "${minimal}" \
  -c "lua require('plenary.test_harness').test_directory('./tests/bench/', { minimal_init = '${minimal}', sequential = true })" \
  | tee "${tempfile}"

errors=$(sed 's/\x1b\[[0-9;]*m//g' "${tempfile}" | awk '/(Errors|Failed) :/ {print $3}' | grep -v '0')

rm "${tempfile}"

if [[ -n $errors ]]; then
  echo "Benchmarks failed (budget exceeded or error)"
  exit 1
fi

exit 0
